                <div className="aspect-[4/5] bg-white mb-10 overflow-hidden border border-gray-100 shadow-sm transition-all duration-1000 group-hover:shadow-2xl group-hover:-translate-y-4">
                   <img src={p.images.hero} alt={p.name} className="w-full h-full object-cover grayscale-[0.3] transition-all duration-[2000ms] group-hover:grayscale-0 group-hover:scale-110" />
                   <div className="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity" />
                </div>
                <div className="flex justify-between items-start px-2">
                   <div>
                      <span className="text-[10px] font-black uppercase tracking-widest text-gold mb-3 block">{p.category}</span>
                      <h3 className="text-3xl font-chubbo tracking-tight group-hover:text-gold transition-colors">{p.name}</h3>
                   </div>
                   <p className="text-2xl font-chubbo text-black/80">${p.price.toLocaleString()}</p>
                </div>
              </Link>
            ))}
            {PRODUCTS.length === 1 && (
              <div className="md:col-span-3 py-48 text-center bg-white border border-dashed border-gray-200 rounded-sm">
                 <p className="text-gray-300 font-light italic text-xl tracking-widest">"More signature artifacts are being recalibrated. Return soon."</p>
              </div>
            )}
         </div>
      </section>

      {/* IMMERSIVE MODAL */}
      <AnimatePresence>
        {showViewer && (
          <ImmersiveViewer image={activeImage} onClose={() => setShowViewer(false)} />
        )}
      </AnimatePresence>
      
    </main>
  );
}
